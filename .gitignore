# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# build output
/dist/
/.astro/
/.vinext/
/.wrangler/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# local generated output
/outputs/
/work/
/.playwright-cli/

# local product and design records; the GitHub repository will be public
/PRODUCT.md
/DESIGN.md
/.impeccable/
/design/
