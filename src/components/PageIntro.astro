---
interface Props {
  title: string;
  label?: string;
}

const { title, label } = Astro.props;
---

<header class="page-intro">
  <div class="page-intro__heading">
    {label && <p class="page-intro__label">{label}</p>}
    <h1>{title}</h1>
  </div>
  <div class="page-intro__body"><slot /></div>
</header>
