---
import { site } from "../config/site";
import { withBase } from "../lib/url";

interface Props {
  path: string;
  overHero?: boolean;
}

const { path, overHero = false } = Astro.props;
const homePath = withBase("/");
const substackUrl = site.substack.url.trim();
---

<header class:list={["site-header", { "site-header--hero": overHero }]} data-site-header>
  <a class="site-mark" href={homePath} aria-label={`${site.name}, home`}>
    <span aria-hidden="true">JWD</span>
  </a>
  <nav aria-label="Primary navigation">
    <ul>
      {
        site.nav.map((item) => {
          const external = item.href === "/blog/" && Boolean(substackUrl);
          const href = external ? substackUrl : withBase(item.href);
          const isHome = item.href === "/";
          const active = external ? false : isHome ? path === href : path.startsWith(href);
          return (
            <li>
              <a href={href} aria-current={active ? "page" : undefined}>
                {item.label}
                {external && <span class="visually-hidden"> on Substack</span>}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-site-header]");

  if (header?.classList.contains("site-header--hero")) {
    let animationFrame = 0;

    const updateHeader = () => {
      animationFrame = 0;
      header.classList.toggle("site-header--scrolled", window.scrollY > 12);
    };

    const scheduleHeaderUpdate = () => {
      if (animationFrame === 0) {
        animationFrame = window.requestAnimationFrame(updateHeader);
      }
    };

    updateHeader();
    window.addEventListener("scroll", scheduleHeaderUpdate, { passive: true });
  }
</script>
