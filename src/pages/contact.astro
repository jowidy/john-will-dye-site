---
import BaseLayout from "../components/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import { site } from "../config/site";
---

<BaseLayout title="Contact" description="Contact and public profiles for John Will Dye.">
  <section class="page-shell">
    <PageIntro title="Contact">
      <p>{site.copy.contactIntro}</p>
    </PageIntro>
    <div class="contact-route">
      <div>
        <h2>Readers</h2>
        <p>
          Essays and updates live on the <a href={site.substack.url}>Substack blog</a>. Follow along on{" "}
          <a href={site.ream.url}>Ream</a> for fiction, or find me on Goodreads, X, and Facebook below.
        </p>
      </div>
      <div>
        <h2>Representation</h2>
        <p>
          John is represented by <a href={site.representation.profileUrl}>{site.representation.agent}</a>{" "}at{" "}
          <a href={site.representation.contactUrl}>{site.representation.agency}</a>.
        </p>
        <p>
          Rights and professional inquiries:<br />
          <a href={`mailto:${site.representation.email}`}>{site.representation.email}</a>
        </p>
      </div>
    </div>
    <ul class="social-list">
      {
        site.socials.map((social) => (
          <li>
            <a href={social.href} rel="me noopener noreferrer" target="_blank">
              {social.label}<span class="visually-hidden"> (opens in a new tab)</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .contact-route {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 7rem);
    max-width: 82rem;
    margin: 0 auto;
  }

  .contact-route > div {
    padding-top: 1.25rem;
    border-top: 0.4rem solid var(--mineral);
  }

  h2 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 2.5rem;
  }

  p {
    max-width: 34rem;
    margin: 0;
  }

  p + p {
    margin-top: 1rem;
  }

  a {
    color: var(--coral-dark);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .contact-route {
      grid-template-columns: 1fr;
    }
  }
</style>
