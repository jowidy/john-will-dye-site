---
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import ProseLayout from "../../components/ProseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("journal", ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<"journal">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <ProseLayout title={entry.data.title} meta={date.format(entry.data.published)}>
    <Content />
  </ProseLayout>
</BaseLayout>
