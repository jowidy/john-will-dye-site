---
import { getCollection } from "astro:content";
import BaseLayout from "../../components/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import Placeholder from "../../components/Placeholder.astro";
import ArchiveList from "../../components/ArchiveList.astro";
import { site } from "../../config/site";

const date = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
const entries = (await getCollection("journal", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);
const items = entries.map((entry) => ({
  title: entry.data.title,
  meta: date.format(entry.data.published),
  href: `/journal/${entry.id}/`,
  description: entry.data.description,
}));
---

<BaseLayout title="Journal" description="News and updates from John Will Dye.">
  <section class="page-shell">
    <PageIntro title="Journal">
      <Placeholder text={site.copy.journalIntro} block />
    </PageIntro>
    <ArchiveList items={items} emptyText="No public journal entries yet." />
  </section>
</BaseLayout>
