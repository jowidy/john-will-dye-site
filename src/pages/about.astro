---
import { getImage, Image } from "astro:assets";
import BaseLayout from "../components/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import portraitOriginal from "../assets/john-dye-portrait.png";
import portrait from "../assets/john-dye-portrait-transparent.png";
import { site } from "../config/site";

const socialPortrait = await getImage({
  src: portraitOriginal,
  width: 760,
  format: "webp",
  quality: 86,
});
---

<BaseLayout title="About" description="About fiction writer John Will Dye." image={socialPortrait.src}>
  <section class="page-shell page-shell--sky" itemscope itemtype="https://schema.org/Person">
    <meta itemprop="name" content={site.name} />
    <PageIntro title="About John">
      <p>{site.copy.aboutShort}</p>
    </PageIntro>
    <div class="about-grid">
      <div class="about-copy">
        {site.copy.aboutLong.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <aside>
        <figure class="about-portrait">
          <div class="about-portrait__frame">
            <Image
              src={portrait}
              alt="John Will Dye"
              widths={[480, 760, 999]}
              sizes="(max-width: 760px) min(88vw, 26rem), min(30vw, 24rem)"
              format="webp"
              quality={90}
              loading="eager"
              itemprop="image"
            />
          </div>
        </figure>
        <h2>Representation</h2>
        <p>
          John is represented by <a href={site.representation.profileUrl}>{site.representation.agent}</a>{" "}at{" "}
          <a href={site.representation.contactUrl}>{site.representation.agency}</a>.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.65fr);
    gap: clamp(3rem, 8vw, 9rem);
    max-width: 82rem;
    margin: 0 auto;
  }

  .about-copy {
    min-height: 20rem;
  }

  .about-copy p {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(1.15rem, 1.6vw, 1.32rem);
  }

  .about-copy p + p {
    margin-top: 1.4rem;
  }

  .about-portrait {
    position: relative;
    isolation: isolate;
    width: min(100%, 24rem);
    margin: 0 0 3.2rem;
  }

  .about-portrait::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    background: var(--coral);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 1.8rem), calc(100% - 1.8rem) 100%, 0 100%);
    content: "";
    transform: translate(0.8rem, 0.9rem);
  }

  .about-portrait__frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--sun);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 1.8rem), calc(100% - 1.8rem) 100%, 0 100%);
  }

  .about-portrait__frame :global(img) {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    max-width: none;
    height: auto;
  }

  aside {
    align-self: start;
    padding-top: 1.2rem;
    border-top: 0.4rem solid var(--mineral);
  }

  aside h2 {
    margin: 0 0 0.8rem;
    font-family: var(--font-display);
    font-size: 2.2rem;
  }

  aside p {
    margin: 0;
  }

  aside a {
    color: var(--coral-dark);
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-copy {
      min-height: 0;
    }

    aside {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(12rem, 0.75fr);
      gap: 0 2rem;
      align-items: start;
    }

    .about-portrait {
      grid-row: 1 / span 2;
      margin-bottom: 0;
    }
  }

  @media (max-width: 540px) {
    aside {
      display: block;
    }

    .about-portrait {
      width: min(92%, 24rem);
      margin-bottom: 3.2rem;
    }
  }
</style>
