---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../components/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import { site } from "../../config/site";
import polaccaCover from "../../assets/fiction/polacca-cover.png";
import morphemeCover from "../../assets/fiction/a-memorable-morpheme-cover.png";

const entries = (await getCollection("fiction", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.order - a.data.order || (b.data.year ?? 0) - (a.data.year ?? 0),
);

const covers = {
  polacca: {
    src: polaccaCover,
    alt: "Polacca cover: an orange desert settlement beneath an expansive blue sky.",
  },
  "a-memorable-morpheme": {
    src: morphemeCover,
    alt: "A Memorable Morpheme cover: a shadowed figure, worn papers, and a bright doorway in a dark room.",
  },
} as const;

const stories = entries.map((entry) => ({
  entry,
  cover: covers[entry.id as keyof typeof covers],
  meta:
    entry.data.status === "coming-soon"
      ? "Coming Soon"
      : (entry.data.publication ?? "Published"),
}));
---

<BaseLayout title="Fiction" description="Stories by John Will Dye.">
  <section class="page-shell page-shell--sky fiction-page">
    <PageIntro title="Fiction" label="Stories">
      <p>{site.copy.fictionIntro}</p>
    </PageIntro>

    <div class="story-shelf">
      {
        stories.map(({ entry, cover, meta }, index) => (
          <article class:list={["story", index % 2 === 1 && "story--reverse", `story--${entry.id}`]}>
            <div class="story__cover-wrap">
              {cover && (
                <Image
                  class="story__cover"
                  src={cover.src}
                  alt={cover.alt}
                  widths={[360, 540, 720]}
                  sizes="(max-width: 760px) 78vw, 30vw"
                  format="webp"
                  quality={90}
                  loading={index === 0 ? "eager" : "lazy"}
                />
              )}
            </div>

            <div class="story__copy">
              <div class="story__labels">
                <p class:list={["story__status", entry.data.status === "coming-soon" && "story__status--soon"]}>
                  {meta}
                </p>
                {entry.data.tags.length > 0 && (
                  <ul class="story__tags" aria-label={`Tags for ${entry.data.title}`}>
                    {entry.data.tags.map((tag) => <li>{tag}</li>)}
                  </ul>
                )}
              </div>
              <h2>{entry.data.title}</h2>
              <p class="story__teaser">{entry.data.description}</p>
              {entry.data.url && (
                <a class="story__action" href={entry.data.url} rel="noopener noreferrer">
                  Read the story <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .fiction-page {
    overflow: hidden;
    padding-inline: 0;
  }

  .fiction-page :global(.page-intro) {
    padding-inline: var(--gutter);
  }

  .story-shelf {
    display: grid;
    gap: clamp(6rem, 12vw, 11rem);
    max-width: 94rem;
    margin: 0 auto;
  }

  .story {
    position: relative;
    display: grid;
    grid-template-columns: minmax(16rem, 0.72fr) minmax(24rem, 1.28fr);
    gap: clamp(3rem, 8vw, 9rem);
    align-items: center;
    padding: clamp(2rem, 5vw, 5rem) var(--gutter);
    isolation: isolate;
  }

  .story::before {
    position: absolute;
    z-index: -1;
    inset: 10% 0 4% 19%;
    background: var(--sun);
    clip-path: polygon(6% 0, 100% 0, 94% 100%, 0 92%);
    content: "";
  }

  .story--reverse {
    grid-template-columns: minmax(24rem, 1.28fr) minmax(16rem, 0.72fr);
  }

  .story--reverse::before {
    inset: 4% 17% 9% 0;
    background: var(--midnight);
    clip-path: polygon(0 8%, 94% 0, 100% 92%, 6% 100%);
  }

  .story__cover-wrap {
    position: relative;
    justify-self: center;
    width: min(100%, 28rem);
  }

  .story--reverse .story__cover-wrap {
    grid-column: 2;
  }

  .story__cover-wrap :global(img) {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    background: var(--night-deep);
    box-shadow: 1.1rem 1.2rem 0 rgb(4 17 38 / 0.28);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .story--reverse .story__cover-wrap :global(img) {
    box-shadow: -1.1rem 1.2rem 0 rgb(217 67 47 / 0.72);
  }

  .story__copy {
    max-width: 38rem;
  }

  .story--reverse .story__copy {
    grid-row: 1;
    grid-column: 1;
    justify-self: end;
    color: var(--sky);
  }

  .story__labels,
  .story__tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
  }

  .story__labels {
    margin-bottom: 1.3rem;
  }

  .story__status {
    display: inline-block;
    margin: 0;
    color: var(--mineral);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.075em;
    text-transform: uppercase;
  }

  .story__status--soon {
    padding: 0.45rem 0.75rem 0.38rem;
    background: var(--coral);
    color: white;
    clip-path: polygon(0 0, 100% 0, calc(100% - 0.45rem) 100%, 0 100%);
  }

  .story__tags {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .story__tags li {
    padding: 0.42rem 0.72rem 0.36rem;
    background: var(--midnight);
    box-shadow: 0.2rem 0.2rem 0 var(--coral);
    color: var(--sky);
    clip-path: polygon(0.35rem 0, 100% 0, calc(100% - 0.22rem) 100%, 0 92%);
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.055em;
    line-height: 1;
    text-transform: uppercase;
    transform: rotate(-1.25deg);
  }

  .story__tags li:nth-child(even) {
    background: var(--mineral);
    transform: translateY(0.08rem) rotate(1deg);
  }

  .story--reverse .story__tags li {
    background: var(--sun);
    box-shadow: 0.2rem 0.2rem 0 var(--coral);
    color: var(--ink);
  }

  .story--reverse .story__tags li:nth-child(even) {
    background: var(--coral);
    box-shadow: 0.2rem 0.2rem 0 var(--sun);
    color: white;
  }

  .story h2 {
    max-width: 10ch;
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(4rem, 8vw, 7.2rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 0.78;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .story__teaser {
    max-width: 35rem;
    margin: 2rem 0 0;
    font-size: clamp(1.1rem, 1.7vw, 1.32rem);
    line-height: 1.62;
    white-space: pre-line;
  }

  .story__action {
    display: inline-flex;
    gap: 1.2rem;
    align-items: baseline;
    margin-top: 2rem;
    padding-bottom: 0.25rem;
    border-bottom: 3px solid var(--coral);
    color: var(--ink);
    font-family: var(--font-display);
    font-size: 1.45rem;
    font-weight: 700;
    text-decoration: none;
  }

  .story__action:hover {
    color: var(--coral-dark);
  }

  .story--reverse .story__action {
    color: var(--sky);
  }

  .story--reverse .story__action:hover {
    color: var(--sun);
  }

  .story__action span {
    color: var(--coral);
    transition: transform 160ms ease;
  }

  .story__action:hover span {
    transform: translate(0.15rem, -0.15rem);
  }

  @media (hover: hover) {
    .story__cover-wrap:hover :global(img) {
      transform: translateY(-0.4rem) rotate(-0.4deg);
      box-shadow: 1.4rem 1.6rem 0 rgb(4 17 38 / 0.3);
    }

    .story--reverse .story__cover-wrap:hover :global(img) {
      transform: translateY(-0.4rem) rotate(0.4deg);
      box-shadow: -1.4rem 1.6rem 0 rgb(217 67 47 / 0.74);
    }
  }

  @media (max-width: 760px) {
    .story-shelf {
      gap: 6rem;
    }

    .story,
    .story--reverse {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      padding-block: 3rem 4rem;
    }

    .story::before {
      inset: 18% 0 0 9%;
    }

    .story--reverse::before {
      inset: 18% -1rem 0 -1rem;
    }

    .story__cover-wrap,
    .story--reverse .story__cover-wrap {
      grid-row: 1;
      grid-column: 1;
      width: min(78vw, 24rem);
    }

    .story__copy,
    .story--reverse .story__copy {
      grid-row: 2;
      grid-column: 1;
      justify-self: start;
    }

    .story h2 {
      font-size: clamp(3.7rem, 18vw, 5.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .story__cover-wrap :global(img),
    .story__action span {
      transition: none;
    }
  }
</style>
